#!/bin/sh
# Maven Wrapper script for Unix
# Downloads Maven if not cached, then runs it

set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
    DIST_URL=$(grep 'distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
fi

MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.9"
MVN_CMD="$MAVEN_HOME/bin/mvn"

if [ ! -f "$MVN_CMD" ]; then
    echo "Downloading Maven..."
    mkdir -p "$MAVEN_HOME"
    TMPFILE=$(mktemp /tmp/maven-XXXXXX.zip)
    curl -fsSL "$DIST_URL" -o "$TMPFILE"
    unzip -qo "$TMPFILE" -d "$HOME/.m2/wrapper/dists/"
    rm -f "$TMPFILE"
    # Move contents up if nested
    if [ -d "$HOME/.m2/wrapper/dists/apache-maven-3.9.9" ]; then
        MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.9"
        MVN_CMD="$MAVEN_HOME/bin/mvn"
    fi
fi

exec "$MVN_CMD" "$@"
